{
    "causal_graph": {
        "pendulum": [],
        "light": [],
        "shadow_length": ["pendulum","light"],
        "shadow_position": ["pendulum","light"],
        "image": ["pendulum","light","shadow_length", "shadow_position"]
    },

    "attribute_size": {
        "pendulum": 1,
        "light": 1,
        "shadow_length": 1,
        "shadow_position" : 1
    },

    "mechanism_models": {

        "No_Beard": {
            "model_type": "flow",
            "model_class": "NoBeardFlow",
            "module": "models.flows",
            "params": {
                "layers": 3,
                "lr": 1e-3,
                "batch_size_train" : 64,
                "batch_size_val" : 64,
                "patience" : 5,
                "max_epochs" : 1,
                "train_val_split" : 0.8
            }
        },

        "Bald": {
            "model_type": "flow",
            "model_class": "BaldFlow",
            "module": "models.flows",
            "params": {
                "layers": 3,
                "lr": 1e-3,
                "batch_size_train" : 64,
                "batch_size_val" : 64,
                "patience" : 5,
                "max_epochs" : 1,
                "train_val_split" : 0.8
            }
        },

        "image": {
            "model_type": "vae",
            "model_class": "CelebaCondVAE",
            "module": "models.vaes",
            "params": {
                "n_chan" : [3, 32, 64, 128, 256, 256],
                "latent_dim" : 16,
                "hidden_dim": 256,
                "beta" : 5,
                "lr" : 1e-3,
                "gradient_clip_val": 350,
                "batch_size_train" : 128,
                "batch_size_val" : 256,
                "patience" : 50,
                "max_epochs" : 1000,
                "weight_decay": 0,
                "ema": "True",
                "fixed_logvar": "False"
            }
        }
    },

    "dataset": "pendulum",
    "checkpoint_dir": "./checkpoints/celeba/complex/trained_scm"
}
